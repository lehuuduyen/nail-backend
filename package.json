{
  "name": "nail-backend",
  "version": "1.0.0",
  "description": "Nail salon management REST API",
  "main": "src/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "seed": "node src/seeders/seed.js",
    "seed:transactions": "node src/seeders/seedTransactions.js",
    "seed:services": "node src/seeders/realServices.js",
    "seed:giftcard": "node src/scripts/seedGiftCardPromo.js",
    "seed:serviceimages": "node src/scripts/seedServiceImages.js",
    "seed:blog-seo": "node src/scripts/upsertSeoBlogPosts.js",
    "seed:blog-services": "node src/scripts/upsertNailServiceBlogPosts.js",
    "reset-admin": "node src/scripts/resetAdminPassword.js",
    "db:sync": "node -e \"require('dotenv').config(); require('./src/config/database').sync({ force: true }).then(() => { console.log('DB synced'); process.exit(0); }).catch((e) => { console.error(e); process.exit(1); })\"",
    "db:alter": "node -e \"require('dotenv').config(); require('./src/config/database').sync({ alter: true }).then(() => { console.log('DB alter OK'); process.exit(0); }).catch((e) => { console.error(e); process.exit(1); })\"",
    "test:helcim": "node src/scripts/testHelcim.js",
    "blog:generate": "node src/scripts/generateDailyBlogPost.js",
    "blog:cron": "node src/scripts/dailyBlogCron.js",
    "instagram:sync": "node src/scripts/syncInstagramGallery.js",
    "instagram:import": "node src/scripts/importInstagramToGallery.js",
    "instagram:cron": "node src/scripts/instagramCron.js"
  },
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.2",
    "@aws-sdk/client-s3": "^3.1085.0",
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "groq-sdk": "^1.2.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "pg": "^8.13.1",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.5",
    "sharp": "^0.35.3",
    "stripe": "^22.1.1",
    "twilio": "^5.13.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
