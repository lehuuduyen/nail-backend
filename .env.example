DATABASE_URL=postgresql://user:password@localhost:5432/nail_salon
JWT_SECRET=your_secret_key
# macOS often uses port 5000 for AirPlay Receiver — use 5001+ for this API if bind fails
PORT=5001
NODE_ENV=development
# Shared secret for nail-ai-transcription (header X-Nail-Service-Key)
SERVICE_API_KEY=change_this_voice_service_secret

# Helcim API v2 (https://devdocs.helcim.com/) — Integrations → API Access → api-token (test vs live tùy cấu hình đó)
HELCIM_API_TOKEN=
# POS Pay Card (chạm thẻ): mã ghép nối thiết bị — Payment Hardware API POST /devices/{code}/payment/purchase (không phải endpoint cũ smart-terminal). Lấy code trên màn hình máy sau khi bật pairing mode, hoặc GET https://api.helcim.com/v2/devices/ (api-token).
HELCIM_TERMINAL_ID=
HELCIM_WEBHOOK_SECRET=
# Không ghi checkoutToken/secretToken (từng lần initialize) vào đây — backend tạo mới qua Pay.js checkout; repo không đọc HELCIM_JS_*.

# SMS receipts POST /api/receipt/sms
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
